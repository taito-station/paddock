# paddock の環境変数サンプル。`.env` にコピーして使う（`.env` は gitignore 済み）。

# DB 接続先（Postgres）。deployments/compose.yaml で起動した PG を指す。
# worktree ごとに分離する場合は database 名を変える（例: .../paddock_feat_xxx）。
PADDOCK_DB_URL=postgres://paddock:paddock@localhost:5432/paddock

# ログフィルタ（tracing EnvFilter）。
# PADDOCK_LOG=info

# PDF 取り込み元ディレクトリ。
# PADDOCK_PDFS_DIR=pdfs
