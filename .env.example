# paddock の環境変数サンプル。`.env` にコピーして使う（`.env` は gitignore 済み）。

# DB 接続先。
# 現状のアプリ既定は SQLite。`.env` を作る場合もまずこちらを使う:
PADDOCK_DB_URL=sqlite://data/paddock.db?mode=rwc
# Postgres へ移行後は deployments/compose.yaml で起動した PG を指す（後続 PR）:
# PADDOCK_DB_URL=postgres://paddock:paddock@localhost:5432/paddock

# ログフィルタ（tracing EnvFilter）。
# PADDOCK_LOG=info

# PDF 取り込み元ディレクトリ。
# PADDOCK_PDFS_DIR=pdfs
