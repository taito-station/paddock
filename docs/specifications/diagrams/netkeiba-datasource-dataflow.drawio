<mxfile host="app.diagrams.net" modified="2026-06-08T00:00:00.000Z" agent="Claude" version="21.0.0">
  <diagram name="netkeiba当日データソース取り込みフロー" id="netkeiba-datasource-dataflow">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- START -->
        <mxCell id="2" value="START&#xa;paddock-fetch-card" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="500" y="40" width="160" height="40" as="geometry" />
        </mxCell>

        <!-- 入力 -->
        <mxCell id="3" value="入力&#xa;netkeiba race_id (12桁) を直接指定&#xa;or 構成要素 (年/場/回/日/R) を指定" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="120" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="4" edge="1" source="2" target="3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- race_id 構築 -->
        <mxCell id="5" value="race_id 構築ヘルパ&#xa;YYYY + 場2桁 + 回2桁 + 日2桁 + R2桁&#xa;→ netkeiba 12桁 / paddock RaceId を導出" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="440" y="210" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="6" edge="1" source="3" target="5" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- 出馬表 取得済み? -->
        <mxCell id="7" value="出馬表は取得済み？&#xa;fetch_history_contains" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="490" y="310" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="8" edge="1" source="5" target="7" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- netkeiba fetch (shutuba) -->
        <mxCell id="9" value="NetkeibaScraper::fetch_card&#xa;race/shutuba.html を GET (ureq)&#xa;EUC-JP → UTF-8 デコード" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="420" y="430" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="10" value="NO (未取得 or --force)" edge="1" source="7" target="9" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- skip 出馬表 -->
        <mxCell id="11" value="出馬表の保存をスキップ&#xa;(オッズ取得・更新は継続)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="760" y="315" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="12" value="YES" edge="1" source="7" target="11" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- parse -->
        <mxCell id="13" value="shutuba HTML を parse&#xa;RaceCard / HorseEntry (枠番/馬番/馬名/騎手)&#xa;＋ 単勝オッズ・人気 (馬番ごと)&#xa;斤量・性齢は取得するが #28 では破棄" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="410" y="540" width="320" height="80" as="geometry" />
        </mxCell>
        <mxCell id="14" edge="1" source="9" target="13" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- オッズ欠損? -->
        <mxCell id="15" value="単勝オッズ未確定？&#xa;(レース前で空欄)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="490" y="660" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="16" edge="1" source="13" target="15" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- 欠損ハンドリング -->
        <mxCell id="17" value="オッズは空のまま&#xa;(win マップを populate しない)&#xa;出馬表保存は継続" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="760" y="665" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="18" value="YES" edge="1" source="15" target="17" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- 永続化: race_card -->
        <mxCell id="19" value="Repository::save_race_card&#xa;race_cards UPSERT / horse_entries 入替&#xa;fetch_history に出馬表取得を記録" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="410" y="770" width="320" height="70" as="geometry" />
        </mxCell>
        <mxCell id="20" value="NO" edge="1" source="15" target="19" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- 永続化: race_odds -->
        <mxCell id="21" value="Repository::save_race_odds&#xa;race_odds に win 行を upsert&#xa;(bet_type=win / combination_key=馬番 /&#xa; odds / popularity / fetched_at=now)&#xa;★ オッズは変動するため常に最新で上書き" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="410" y="880" width="320" height="90" as="geometry" />
        </mxCell>
        <mxCell id="22" edge="1" source="19" target="21" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- SQLite -->
        <mxCell id="23" value="SQLite&#xa;race_cards / horse_entries / race_odds&#xa;/ fetch_history" style="cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="470" y="1010" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="24" edge="1" source="21" target="23" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- skip 出馬表 → オッズ取得へ合流 -->
        <mxCell id="25" value="netkeiba fetch_card (オッズ取得のみ利用)" style="edgeStyle=orthogonalEdgeStyle;dashed=1;" edge="1" source="11" target="9" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="870" y="430" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 欠損 → race_card 保存へ合流 -->
        <mxCell id="26" style="edgeStyle=orthogonalEdgeStyle;dashed=1;" edge="1" source="17" target="19" parent="1">
          <mxGeometry relative="1" as="geometry">
