        </mxCell>

        <!-- Kelly計算 -->
        <mxCell id="21" value="Kelly 計算&#xa;f = (p × b − q) / b&#xa;b = odds − 1, q = 1 − p&#xa;fraction = clamp(f, 0.0, kelly_cap)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="410" y="670" width="300" height="70" as="geometry" />
