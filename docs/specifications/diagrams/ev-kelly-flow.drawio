        <mxCell id="17" value="EV &gt; 閾値？&#xa;(三連単: trifecta_ev_threshold&#xa; その他: ev_threshold)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
