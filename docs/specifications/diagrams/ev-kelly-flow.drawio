        <!-- 各馬券種の候補生成 (並行) -->
        <mxCell id="5" value="各馬券種の候補生成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="210" width="200" height="45" as="geometry" />
        </mxCell>

        <!-- 入力 → 候補生成 -->
        <mxCell id="6" edge="1" source="3" target="5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

