        <mxCell id="7" value="単勝・複勝&#xa;P = win_prob / show_prob" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="320" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- 馬連・馬単 -->
        <mxCell id="8" value="馬連・馬単&#xa;P = Harville 2頭式" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="320" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- 三連複・三連単 -->
        <mxCell id="9" value="三連複・三連単&#xa;P = Harville 3頭式 (全順列合算)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
