          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- EV計算 -->
        <mxCell id="13" value="EV 計算&#xa;ev = probability × odds" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=11;" vertex="1" parent="1">
