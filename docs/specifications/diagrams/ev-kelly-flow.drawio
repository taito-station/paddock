        <mxCell id="23" value="優先度ソート&#xa;馬連 &gt; 馬単 &gt; 三連複 &gt; 単勝 &gt; 複勝&#xa;(三連単は EV &gt; trifecta_ev_threshold のみ)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
