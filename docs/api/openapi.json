{
  "openapi": "3.1.0",
  "info": {
    "title": "paddock REST API",
    "description": "競馬予想・分析の REST API。read 系（#33）と予想セッション write 系（#53）を提供する。",
    "license": {
      "name": "Proprietary"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/api/analyze/course": {
      "get": {
        "tags": [
          "analyze"
        ],
        "summary": "コース（場×距離×馬場）の枠順別統計。",
        "operationId": "analyze_course",
        "parameters": [
          {
            "name": "venue",
            "in": "query",
            "description": "開催場（英字スラッグまたは日本語）。",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "distance",
            "in": "query",
            "description": "距離[m]。",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          },
          {
            "name": "surface",
            "in": "query",
            "description": "芝/ダート（`turf` / `dirt`）。",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "コースの枠順別統計",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CourseStatsResponse"
                }
              }
            }
          },
          "400": {
            "description": "パラメータ不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "500": {
            "description": "内部エラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/analyze/horse": {
      "get": {
        "tags": [
          "analyze"
        ],
        "summary": "馬の成績統計。",
        "operationId": "analyze_horse",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "description": "対象の名前（完全一致。あいまい検索は #50）。",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "馬の成績統計",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HorseStatsResponse"
                }
              }
            }
          },
          "400": {
            "description": "名前不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "500": {
            "description": "内部エラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/analyze/jockey": {
      "get": {
        "tags": [
          "analyze"
        ],
        "summary": "騎手の成績統計。",
        "operationId": "analyze_jockey",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "description": "対象の名前（完全一致。あいまい検索は #50）。",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "騎手の成績統計",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JockeyStatsResponse"
                }
              }
            }
          },
          "400": {
            "description": "名前不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "500": {
            "description": "内部エラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/analyze/trainer": {
      "get": {
        "tags": [
          "analyze"
        ],
        "summary": "調教師の成績統計。",
        "operationId": "analyze_trainer",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "description": "対象の名前（完全一致。あいまい検索は #50）。",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "調教師の成績統計",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrainerStatsResponse"
                }
              }
            }
          },
          "400": {
            "description": "名前不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "500": {
            "description": "内部エラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/races": {
      "get": {
        "tags": [
          "races"
        ],
        "summary": "レース一覧（指定日）。",
        "operationId": "list_races",
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "description": "開催日（`YYYY-MM-DD`）。",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "指定日のレース一覧",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RaceListResponse"
                }
              }
            }
          },
          "400": {
            "description": "日付フォーマット不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "500": {
            "description": "内部エラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/races/{race_id}": {
      "get": {
        "tags": [
          "races"
        ],
        "summary": "出馬表（race card）。",
        "operationId": "get_race_card",
        "parameters": [
          {
            "name": "race_id",
            "in": "path",
            "description": "レース ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "出馬表",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RaceCardResponse"
                }
              }
            }
          },
          "400": {
            "description": "レース ID 不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "404": {
            "description": "未存在のレース",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "500": {
            "description": "内部エラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/races/{race_id}/prediction": {
      "get": {
        "tags": [
          "races"
        ],
        "summary": "確率推定（win/place/show）。",
        "operationId": "get_prediction",
        "parameters": [
          {
            "name": "race_id",
            "in": "path",
            "description": "レース ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "track_condition",
            "in": "query",
            "description": "馬場状態（`良` / `稍重` / `重` / `不良`。略記 `稍` / `不` も可）。未指定なら馬場項なし。",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          {
            "name": "blend_alpha",
            "in": "query",
            "description": "市場オッズ（単勝）とのブレンド係数 `[0,1]`。未指定はモデルのみ。",
            "required": false,
            "schema": {
              "type": [
                "number",
                "null"
              ],
              "format": "double"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "馬ごとの確率",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PredictionResponse"
                }
              }
            }
          },
          "400": {
            "description": "クエリ不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "404": {
            "description": "出馬表が無いレース",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "500": {
            "description": "内部エラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/sessions/{date}": {
      "get": {
        "tags": [
          "sessions"
        ],
        "summary": "セッション収支サマリ + 明細。",
        "operationId": "get_session_summary",
        "parameters": [
          {
            "name": "date",
            "in": "path",
            "description": "開催日 YYYY-MM-DD",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "セッション収支 + 明細",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionSummaryResponse"
                }
              }
            }
          },
          "400": {
            "description": "日付不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "404": {
            "description": "未作成のセッション",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "500": {
            "description": "内部エラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "sessions"
        ],
        "summary": "セッション新規作成。",
        "operationId": "create_session",
        "parameters": [
          {
            "name": "date",
            "in": "path",
            "description": "開催日 YYYY-MM-DD",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSessionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "作成したセッションのサマリ",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionSummaryResponse"
                }
              }
            }
          },
          "400": {
            "description": "budget 不正・日付不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "409": {
            "description": "同一開催日のセッションが既に存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "500": {
            "description": "内部エラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/sessions/{date}/races/{race_id}/odds:refresh": {
      "post": {
        "tags": [
          "sessions"
        ],
        "summary": "オッズをライブ取得して保存（#51, read-through）。",
        "operationId": "odds_refresh",
        "parameters": [
          {
            "name": "date",
            "in": "path",
            "description": "開催日 YYYY-MM-DD",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "race_id",
            "in": "path",
            "description": "レース ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "取得結果（未取得は fetched=false・HTTP は 200）",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OddsRefreshResponse"
                }
              }
            }
          },
          "400": {
            "description": "日付/ID 不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "404": {
            "description": "未作成のセッション",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "500": {
            "description": "内部エラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/sessions/{date}/races/{race_id}/outcome": {
      "post": {
        "tags": [
          "sessions"
        ],
        "summary": "1 レース分の賭け金・払戻を記録（残高ガード・1 トランザクション）。",
        "operationId": "record_outcome",
        "parameters": [
          {
            "name": "date",
            "in": "path",
            "description": "開催日 YYYY-MM-DD",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "race_id",
            "in": "path",
            "description": "レース ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecordOutcomeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "更新後のセッションサマリ",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionSummaryResponse"
                }
              }
            }
          },
          "400": {
            "description": "残高超過・日付/ID 不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "404": {
            "description": "未作成のセッション",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "409": {
            "description": "当該レースの outcome が既に記録済み",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "500": {
            "description": "内部エラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/sessions/{date}/results:refresh": {
      "post": {
        "tags": [
          "sessions"
        ],
        "summary": "確定結果を取得して払戻を自動補完（#40, 冪等）。",
        "operationId": "results_refresh",
        "parameters": [
          {
            "name": "date",
            "in": "path",
            "description": "開催日 YYYY-MM-DD",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "精算レポート（pending_races に未確定が出る）",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SettleReportResponse"
                }
              }
            }
          },
          "400": {
            "description": "日付不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "404": {
            "description": "未作成のセッション",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "500": {
            "description": "内部エラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BetInput": {
        "type": "object",
        "description": "outcome 記録の 1 買い目（リクエスト）。race_id はパスから取るため含めない。",
        "required": [
          "bet_type",
          "combination",
          "stake"
        ],
        "properties": {
          "bet_type": {
            "type": "string",
            "description": "馬券種ラベル（例 `単勝` / `馬連`）。"
          },
          "combination": {
            "type": "string",
            "description": "組み合わせコード（例 `7` / `7-14`）。"
          },
          "ev": {
            "type": "number",
            "format": "double",
            "description": "期待値（参考値）。"
          },
          "payout": {
            "type": "integer",
            "format": "int64",
            "description": "払戻（円、記録時点で不明なら 0。results:refresh で確定値に上書きされる）。",
            "minimum": 0
          },
          "stake": {
            "type": "integer",
            "format": "int64",
            "description": "賭け金（円）。",
            "minimum": 0
          }
        }
      },
      "CourseStatsResponse": {
        "type": "object",
        "description": "`GET /api/analyze/course?venue=&distance=&surface=` のレスポンス。",
        "required": [
          "venue",
          "distance",
          "surface",
          "by_gate_group"
        ],
        "properties": {
          "by_gate_group": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GroupStatSchema"
            }
          },
          "distance": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "surface": {
            "type": "string"
          },
          "venue": {
            "type": "string"
          }
        }
      },
      "CreateSessionRequest": {
        "type": "object",
        "description": "`POST /api/sessions/{date}` のリクエスト。",
        "required": [
          "budget"
        ],
        "properties": {
          "budget": {
            "type": "integer",
            "format": "int64",
            "description": "初期予算（円）。1 以上。",
            "minimum": 1
          }
        }
      },
      "ErrorBody": {
        "type": "object",
        "description": "エラーレスポンス本文。`{ \"error\": { \"code\": ..., \"message\": ... } }`。",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorDetail"
          }
        }
      },
      "ErrorDetail": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "機械可読なエラーコード（`bad_request` / `not_found` / `conflict` / `internal`）。"
          },
          "message": {
            "type": "string",
            "description": "人間可読なエラーメッセージ。"
          }
        }
      },
      "GroupStatSchema": {
        "type": "object",
        "description": "あるカテゴリ 1 区分の成績（出走数＋勝/連対/複勝の件数とレート）。",
        "required": [
          "label",
          "starts",
          "wins",
          "places",
          "shows",
          "win_rate",
          "place_rate",
          "show_rate"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "place_rate": {
            "type": "number",
            "format": "double"
          },
          "places": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "show_rate": {
            "type": "number",
            "format": "double"
          },
          "shows": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "starts": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "win_rate": {
            "type": "number",
            "format": "double"
          },
          "wins": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "HorseEntrySchema": {
        "type": "object",
        "description": "出馬表の 1 頭。",
        "required": [
          "gate_num",
          "horse_num",
          "horse_name"
        ],
        "properties": {
          "gate_num": {
            "type": "integer",
            "format": "int32",
            "description": "枠番（1..=8）。",
